{
  "build": {
    "env": {
      "VITE_BACKEND_URL": "https://chat-app-5suh.onrender.com"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://chat-app-5suh.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://chat-app-5suh.onrender.com/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
